# ---- Firebase (Project settings > General > Your apps > Web app config) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- Firebase Cloud Messaging Web Push ----
# Project settings > Cloud Messaging > Web configuration > "Web Push certificates" > Key pair
VITE_FIREBASE_VAPID_KEY=

# ---- Cloudinary (for photo/video upload) ----
# Dashboard > your Cloud name; and Settings > Upload > add an UNSIGNED upload preset
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ---- GIPHY (GIF search) ----
# https://developers.giphy.com -> Create an App -> "API" -> copy the API Key
VITE_GIPHY_API_KEY=

# ---- Push endpoint (your deployed Cloudflare Worker URL) ----
# e.g. https://pocket-chat-push.<your-subdomain>.workers.dev
VITE_PUSH_ENDPOINT=
